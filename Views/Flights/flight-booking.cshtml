@model ProjetoHotelAviao.Models.Flight
@{
    ViewData["Title"] = "Book Flight - TravelSys";
    
    // Read selections from query string
    var isVolta = Context.Request.Query["volta"].FirstOrDefault() == "true";
    var multiplier = isVolta ? 2 : 1;
    
    var baseFare = Model.Price * multiplier;
    var taxes = 20m * multiplier;
    var serviceFee = 5m * multiplier;
    var total = baseFare + taxes + serviceFee;
}

@section Styles {
    <link rel="stylesheet" href="~/css/flight-booking.css">
}

<div class="main-container">
    <div class="breadcrumbs">
        <nav>
            <a href="#">Turkey</a> <i class="fas fa-chevron-right"></i>
            <a href="#">Istanbul</a> <i class="fas fa-chevron-right"></i>
            <span>CVK Park Bosphorus Hotel Istanbul</span>
        </nav>
    </div>

    <div class="booking-layout">
        <div class="booking-content">
            <!-- Flight Header -->
            <div class="flight-header-section">
                <div class="title-price-row">
                    <h2>@Model.Airline A380 Airbus</h2>
                    <span class="price">R$ @baseFare.ToString("N2")</span>
                </div>
                
                <!-- Ida Schedule Card -->
                <div class="flight-schedule-card">
                    <div class="card-header">
                        <h3>Ida Wed, Dec 8</h3>
                        <span class="duration">@Model.Duration</span>
                    </div>
                    <div class="card-content">
                        <div class="airline-box-bordered">
                            <div class="logo-box">
                                <img src="@Model.Logo" alt="@Model.Airline">
                            </div>
                            <div class="airline-info">
                                <h4>@Model.Airline</h4>
                                <span>Airbus A320</span>
                            </div>
                        </div>
                        <div class="amenities-row">
                            <div class="amenity-item"><i class="fas fa-plane"></i></div>
                            <div class="v-separator"></div>
                            <div class="amenity-item"><i class="fas fa-wifi"></i></div>
                            <div class="v-separator"></div>
                            <div class="amenity-item"><i class="fas fa-stopwatch"></i></div>
                            <div class="v-separator"></div>
                            <div class="amenity-item"><i class="fas fa-utensils"></i></div>
                            <div class="v-separator"></div>
                            <div class="amenity-item"><i class="fas fa-wheelchair"></i></div>
                        </div>
                    </div>
                    <div class="timeline-row">
                        <div class="time-point">
                            <span class="time">@Model.Departure</span>
                            <span class="airport">@Model.From (@Model.From.Substring(0, Math.Min(3, Model.From.Length)).ToUpper())</span>
                        </div>
                        <div class="path-horizontal">
                            <div class="dot"></div>
                            <div class="line"></div>
                            <i class="fas fa-plane"></i>
                            <div class="line"></div>
                            <div class="dot"></div>
                        </div>
                        <div class="time-point">
                            <span class="time">@Model.Arrival</span>
                            <span class="airport">@Model.To (@Model.To.Substring(0, Math.Min(3, Model.To.Length)).ToUpper())</span>
                        </div>
                    </div>
                </div>

                @if (isVolta)
                {
                    <!-- Volta Schedule Card -->
                    <div class="flight-schedule-card" style="margin-top: 20px;">
                        <div class="card-header">
                            <h3>Volta Sat, Dec 11</h3>
                            <span class="duration">@Model.Duration</span>
                        </div>
                        <div class="card-content">
                            <div class="airline-box-bordered">
                                <div class="logo-box">
                                    <img src="@Model.Logo" alt="@Model.Airline">
                                </div>
                                <div class="airline-info">
                                    <h4>@Model.Airline</h4>
                                    <span>Airbus A320</span>
                                </div>
                            </div>
                            <div class="amenities-row">
                                <div class="amenity-item"><i class="fas fa-plane"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-wifi"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-stopwatch"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-utensils"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-wheelchair"></i></div>
                            </div>
                        </div>
                        <div class="timeline-row">
                            <div class="time-point">
                                <span class="time">@Model.Arrival</span>
                                <span class="airport">@Model.To (@Model.To.Substring(0, Math.Min(3, Model.To.Length)).ToUpper())</span>
                            </div>
                            <div class="path-horizontal">
                                <div class="dot"></div>
                                <div class="line"></div>
                                <i class="fas fa-plane" style="transform: rotate(180deg);"></i>
                                <div class="line"></div>
                                <div class="dot"></div>
                            </div>
                            <div class="time-point">
                                <span class="time">@Model.Departure</span>
                                <span class="airport">@Model.From (@Model.From.Substring(0, Math.Min(3, Model.From.Length)).ToUpper())</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Payment Options -->
            <div class="payment-options-box">
                <div class="payment-option selected" id="opt-full" onclick="selectPayment('full')">
                    <div class="option-text">
                        <h4>Pay in full</h4>
                        <p>Pay the total and you are all set</p>
                    </div>
                    <div class="radio-ui">
                        <div class="inner"></div>
                    </div>
                </div>
                <div class="payment-option" id="opt-part" onclick="selectPayment('part')">
                    <div class="option-text">
                        <h4>Pay part now, part later</h4>
                        <p>Pay R$ @((total/2).ToString("N2")) now, and the rest (R$ @((total/2).ToString("N2"))) will be automatically charged later. No extra fees.</p>
                        <a href="#" class="more-info">More info</a>
                    </div>
                    <div class="radio-ui">
                        <div class="inner"></div>
                    </div>
                </div>
            </div>

            <!-- Authentication Section -->
            <form asp-action="Payment" asp-route-id="@Model.Id" asp-route-volta="@(isVolta ? "true" : "false")" method="get" class="auth-booking-section">
                <h3>Login or Sign up to book</h3>
                <div class="input-phone-group">
                    <input type="text" placeholder="Phone Number" required name="phoneNumber">
                </div>
                <p class="auth-notice">We'll call or text you to confirm your number. Standard message and data rates apply. <a href="#">Privacy Policy</a></p>
                <button type="submit" class="btn-continue">Continue</button>
                
                <div class="auth-divider">
                    <div class="line"></div>
                    <span>Or</span>
                    <div class="line"></div>
                </div>

                <div class="social-auth-grid">
                    <button type="button" class="btn-social"><i class="fab fa-facebook-f"></i></button>
                    <button type="button" class="btn-social"><img src="https://www.gstatic.com/images/branding/product/1x/googleg_48dp.png" alt="Google"></button>
                    <button type="button" class="btn-social"><i class="fab fa-apple"></i></button>
                </div>

                <button type="button" class="btn-email-auth">
                    <i class="far fa-envelope"></i> Continue with email
                </button>
            </form>
        </div>

        <!-- Sidebar -->
        <aside class="booking-sidebar">
            <div class="sidebar-summary-card">
                <div class="summary-header">
                    <img src="@(string.IsNullOrEmpty(Model.MainImage) ? "/img/flights/A380.jpg" : Model.MainImage)" alt="Flight" class="summary-img">
                    <div class="summary-info">
                        <span class="class-label">Economy</span>
                        <h4>@Model.Airline A380 Airbus</h4>
                        <div class="rating-box">
                            <span class="score">@Model.Rating</span>
                            <span class="text">Very Good</span>
                            <span class="reviews">@Model.Reviews reviews</span>
                        </div>
                    </div>
                </div>
                <div class="protection-box">
                    <p>Your booking is protected by <strong>golobe</strong></p>
                </div>
                <div class="price-details-box">
                    <h4>Price Details</h4>
                    <div class="price-item">
                        <span>Base Fare</span>
                        <span>R$ @baseFare.ToString("N2")</span>
                    </div>
                    <div class="price-item">
                        <span>Discount</span>
                        <span>R$ 0,00</span>
                    </div>
                    <div class="price-item">
                        <span>Taxes</span>
                        <span>R$ @taxes.ToString("N2")</span>
                    </div>
                    <div class="price-item">
                        <span>Service Fee</span>
                        <span>R$ @serviceFee.ToString("N2")</span>
                    </div>
                    <div class="price-item total">
                        <span>Total</span>
                        <span>R$ @total.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        function selectPayment(type) {
            document.querySelectorAll('.payment-option').forEach(opt => opt.classList.remove('selected'));
            document.getElementById('opt-' + type).classList.add('selected');
        }
    </script>
}