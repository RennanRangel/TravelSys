@model ProjetoHotelAviao.Models.Flight
@{
    ViewData["Title"] = "Payment - TravelSys";
    
    // Read selections from ViewBag (set in controller)
    var isVolta = ViewBag.Volta == true;
    var multiplier = isVolta ? 2 : 1;
    
    var baseFare = Model.Price * multiplier;
    var taxes = (Model.Price * 0.1m) * multiplier; // Using 10% as taxes like in controller
    var serviceFee = 25m * multiplier; // Using 25 like in controller
    var total = baseFare + taxes + serviceFee;
}

@section Styles {
    <link rel="stylesheet" href="~/css/flight-booking.css">
    <link rel="stylesheet" href="~/css/flight-payment.css">
}

<div class="main-container">
    <div class="breadcrumbs">
        <nav>
            <a href="#">Turkey</a> <i class="fas fa-chevron-right"></i>
            <a href="#">Istanbul</a> <i class="fas fa-chevron-right"></i>
            <span>CVK Park Bosphorus Hotel Istanbul</span>
        </nav>
    </div>

    <div class="booking-layout">
        <div class="booking-content">
            <form asp-action="CompletePayment" method="post" id="paymentForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="flightId" value="@Model.Id" />
                <input type="hidden" name="paymentType" id="paymentTypeInput" value="full" />
                <input type="hidden" name="volta" value="@(isVolta ? "true" : "false")" />

                <!-- Flight Header Section -->
                <div class="flight-header-section">
                    <div class="title-price-row">
                        <h2>@Model.Airline A380 Airbus</h2>
                        @{ var displayPriceTotal = total; }
                        <span class="price">R$ @displayPriceTotal.ToString("N2")</span>
                    </div>
                    
                    <!-- Ida Schedule Card -->
                    <div class="flight-schedule-card">
                        <div class="card-header">
                            <h3>Ida Wed, Dec 8</h3>
                            <span class="duration">@Model.Duration</span>
                        </div>
                        <div class="card-content">
                            <div class="airline-box-bordered">
                                <div class="logo-box">
                                    <img src="@Model.Logo" alt="@Model.Airline">
                                </div>
                                <div class="airline-info">
                                    <h4>@Model.Airline</h4>
                                    <span>Airbus A320</span>
                                </div>
                            </div>
                            <div class="amenities-row">
                                <div class="amenity-item"><i class="fas fa-plane"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-wifi"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-stopwatch"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-utensils"></i></div>
                                <div class="v-separator"></div>
                                <div class="amenity-item"><i class="fas fa-wheelchair"></i></div>
                            </div>
                        </div>
                        <div class="timeline-row">
                            <div class="time-point">
                                <span class="time">@Model.Departure</span>
                                <span class="airport">@Model.From (@Model.From.Substring(0, Math.Min(3, Model.From.Length)).ToUpper())</span>
                            </div>
                            <div class="path-horizontal">
                                <div class="line"></div>
                                <i class="fas fa-plane"></i>
                                <div class="line"></div>
                            </div>
                            <div class="time-point">
                                <span class="time">@Model.Arrival</span>
                                <span class="airport">@Model.To (@Model.To.Substring(0, Math.Min(3, Model.To.Length)).ToUpper())</span>
                            </div>
                        </div>
                    </div>

                    @if (isVolta)
                    {
                        <!-- Volta Schedule Card -->
                        <div class="flight-schedule-card" style="margin-top: 20px;">
                            <div class="card-header">
                                <h3>Volta Sat, Dec 11</h3>
                                <span class="duration">@Model.Duration</span>
                            </div>
                            <div class="card-content">
                                <div class="airline-box-bordered">
                                    <div class="logo-box">
                                        <img src="@Model.Logo" alt="@Model.Airline">
                                    </div>
                                    <div class="airline-info">
                                        <h4>@Model.Airline</h4>
                                        <span>Airbus A320</span>
                                    </div>
                                </div>
                                <div class="amenities-row">
                                    <div class="amenity-item"><i class="fas fa-plane"></i></div>
                                    <div class="v-separator"></div>
                                    <div class="amenity-item"><i class="fas fa-wifi"></i></div>
                                    <div class="v-separator"></div>
                                    <div class="amenity-item"><i class="fas fa-stopwatch"></i></div>
                                    <div class="v-separator"></div>
                                    <div class="amenity-item"><i class="fas fa-utensils"></i></div>
                                    <div class="v-separator"></div>
                                    <div class="amenity-item"><i class="fas fa-wheelchair"></i></div>
                                </div>
                            </div>
                            <div class="timeline-row">
                                <div class="time-point">
                                    <span class="time">@Model.Arrival</span>
                                    <span class="airport">@Model.To (@Model.To.Substring(0, Math.Min(3, Model.To.Length)).ToUpper())</span>
                                </div>
                                <div class="path-horizontal">
                                    <div class="line"></div>
                                    <i class="fas fa-plane" style="transform: rotate(180deg);"></i>
                                    <div class="line"></div>
                                </div>
                                <div class="time-point">
                                    <span class="time">@Model.Departure</span>
                                    <span class="airport">@Model.From (@Model.From.Substring(0, Math.Min(3, Model.From.Length)).ToUpper())</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Payment Plan Section -->
                <div class="payment-plan-section">
                    <div class="plan-option selected" id="plan-full" onclick="selectPlan('full')">
                        <div class="option-text">
                            <h4>Pay in full</h4>
                            <p>Pay the total and you are all set</p>
                        </div>
                        <div class="radio-ui">
                            <div class="inner"></div>
                        </div>
                    </div>
                    <div class="plan-option" id="plan-part" onclick="selectPlan('part')">
                        <div class="option-text">
                            <h4>Pay part now, part later</h4>
                            <p>Pay R$ @((total/2).ToString("N2")) now, and the rest (R$ @((total/2).ToString("N2"))) will be automatically charged later. No extra fees.</p>
                            <a href="#" class="more-info">More info</a>
                        </div>
                        <div class="radio-ui">
                            <div class="inner"></div>
                        </div>
                    </div>
                </div>

                <!-- Card Management Section -->
                <div class="card-management-section">
                    @if (ViewBag.UserCards != null && ((IEnumerable<ProjetoHotelAviao.Models.UserCard>)ViewBag.UserCards).Any())
                    {
                        foreach (var card in (IEnumerable<ProjetoHotelAviao.Models.UserCard>)ViewBag.UserCards)
                        {
                            <div class="saved-card selected">
                                <div class="card-brand">
                                    <i class="fab fa-cc-visa"></i>
                                    <span>**** @(card.CardNumber.Length >= 4 ? card.CardNumber.Substring(card.CardNumber.Length - 4) : card.CardNumber)</span>
                                    <span class="expiry">@card.ExpiryDate</span>
                                </div>
                                <div class="radio-ui">
                                    <div class="inner"></div>
                                </div>
                            </div>
                        }
                    }

                    <div class="add-card-dashed-box" onclick="openAddCardModal()">
                        <div class="plus-circle">
                            <i class="fas fa-plus"></i>
                        </div>
                        <span>Add a new card</span>
                    </div>
                </div>
                
                <button type="submit" class="btn-confirm-booking">Confirm Booking</button>
            </form>
        </div>

        <!-- Sidebar -->
        <aside class="booking-sidebar">
            <div class="sidebar-summary-card">
                <div class="summary-header">
                    <img src="@(string.IsNullOrEmpty(Model.MainImage) ? "/img/flights/A380.jpg" : Model.MainImage)" alt="Flight" class="summary-img">
                    <div class="summary-info">
                        <span class="class-label">Economy</span>
                        <h4>@Model.Airline A380 Airbus</h4>
                        <div class="rating-box">
                            <span class="score">@Model.Rating</span>
                            <span class="text">Very Good</span>
                            <span class="reviews">@Model.Reviews reviews</span>
                        </div>
                    </div>
                </div>
                <div class="protection-box">
                    <p>Your booking is protected by <strong>golobe</strong></p>
                </div>
                <div class="price-details-box">
                    <h4>Price Details</h4>
                    <div class="price-item">
                        <span>Base Fare</span>
                        <span>R$ @baseFare.ToString("N2")</span>
                    </div>
                    <div class="price-item">
                        <span>Discount</span>
                        <span>R$ 0,00</span>
                    </div>
                    <div class="price-item">
                        <span>Taxes</span>
                        <span>R$ @taxes.ToString("N2")</span>
                    </div>
                    <div class="price-item">
                        <span>Service Fee</span>
                        <span>R$ @serviceFee.ToString("N2")</span>
                    </div>
                    <div class="price-item total">
                        <span>Total</span>
                        <span>R$ @total.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

<!-- Add New Card Modal (Matches 2112) -->
<div class="modal-overlay" id="addCardModal">
    <div class="modal-card">
        <button class="close-modal" onclick="closeAddCardModal()">&times;</button>
        <h2>Add a new Card</h2>

        <form class="modal-form" asp-controller="Cards" asp-action="AddCard" method="post">
            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
            
            <div class="form-group-outline">
                <label>Card Number</label>
                <div class="input-wrapper">
                    <input type="text" name="cardNumber" placeholder="4321 4321 4321 4321" required>
                    <i class="fab fa-cc-visa"></i>
                </div>
            </div>

            <div class="form-row-outline">
                <div class="form-group-outline">
                    <label>Exp. Date</label>
                    <input type="text" name="expiryDate" placeholder="02/27" required>
                </div>
                <div class="form-group-outline">
                    <label>CVC</label>
                    <input type="text" name="cvc" placeholder="123" required>
                </div>
            </div>

            <div class="form-group-outline">
                <label>Name on Card</label>
                <input type="text" name="nameOnCard" placeholder="John Doe" required>
            </div>

            <div class="form-group-outline">
                <label>Country or Region</label>
                <div class="select-wrapper">
                    <select name="country">
                        <option value="United States">United States</option>
                        <option value="Brazil">Brazil</option>
                    </select>
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>

            <div class="form-checkbox-premium">
                <input type="checkbox" id="modalSaveCard" name="saveCard" value="true" checked>
                <label for="modalSaveCard">Securely save my information for 1-click checkout</label>
            </div>

            <button type="submit" class="btn-modal-add">Add Card</button>

            <p class="modal-terms">
                By confirming your subscription, you allow The Outdoor Inn Crowd Limited to charge your card for this payment and future payments in accordance with their terms. You can always cancel your subscription.
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function selectPlan(type) {
            document.querySelectorAll('.plan-option').forEach(opt => opt.classList.remove('selected'));
            document.getElementById('plan-' + type).classList.add('selected');
            document.getElementById('paymentTypeInput').value = type;
        }
        function openAddCardModal() {
            document.getElementById('addCardModal').classList.add('active');
            document.body.style.overflow = 'hidden'; // Prevent scroll
        }
        function closeAddCardModal() {
            document.getElementById('addCardModal').classList.remove('active');
            document.body.style.overflow = 'auto';
        }
    </script>
}
