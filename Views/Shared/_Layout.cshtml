<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Travel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/_Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout-overrides.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha512-9usAa10IRO0HhonpyAIVpjrylPvoDwiPUiKdWk5t3PyolY1cOd4DSE0Ga+ri4AuTroPR5aQvXU9xC6qOPnzFeg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
     <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow py-4">
    <div class="container-fluid align-items-center">
        <a class="navbar-brand me-4" asp-area="" asp-controller="Home" asp-action="Index">
            <span class="navbar-brand-text">Travel<i class="fas fa-plane-departure navbar-brand-icon"></i></span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
            <ul class="navbar-nav me-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link site-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Flights" ? "active" : "")" asp-area="" asp-controller="Flights" asp-action="Index">
                        <i class="fas fa-plane"></i> <span class="nav-text">Find Flight</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link site-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hotels" ? "active" : "")" asp-area="" asp-controller="Hotels" asp-action="Index">
                        <i class="fas fa-bed"></i> <span class="nav-text">Find Stays</span>
                    </a>
                </li>
            </ul>
         <ul class="navbar-nav ms-auto align-items-center">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-dark d-flex align-items-center gap-2 nav-link-premium" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                             <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=8DD3BB&color=fff" alt="Avatar" class="user-avatar-nav">
                            @User.Identity.Name
                        </a>
                        <div class="dropdown-menu dropdown-menu-end dropdown-menu-user" aria-labelledby="navbarDropdown">
                            <div class="dropdown-user-header">
                                <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=8DD3BB&color=fff" alt="Avatar" class="user-avatar-menu">
                                <div class="user-text-info">
                                <h4>@User.Identity.Name</h4>
                                    <span>Online</span>
                                </div>
                            </div>
                            
                            <div class="dropdown-divider-premium"></div>
                            
                            <a class="dropdown-item-premium" href="/Account">
                                <div class="item-left"><i class="fas fa-user-circle"></i> My account</div>
                                <i class="fas fa-chevron-right chevron-right"></i>
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="dropdown-item-premium" asp-controller="Admin" asp-action="Index">
                                    <div class="item-left"><i class="fas fa-user-shield"></i> Admin Panel</div>
                                    <i class="fas fa-chevron-right chevron-right"></i>
                                </a>
                            }
                            <a class="dropdown-item-premium" href="/Account?tab=payments">
                                <div class="item-left"><i class="fas fa-credit-card"></i> Payments</div>
                                <i class="fas fa-chevron-right chevron-right"></i>
                            </a>
                            
                            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                                <button type="submit" class="dropdown-item-premium">
                                    <div class="item-left"><i class="fas fa-sign-out-alt"></i> Logout</div>
                                </button>
                            </form>
                        </div>
                    </li>
                }
                else
                {
                    <li class="nav-item d-flex align-items-center">
                        <a class="nav-link site-nav-link fw-bold me-3" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item d-flex align-items-center">
                        <a class="btn btn-dark text-white fw-bold px-4 btn-signup-nav" asp-controller="Account" asp-action="Signup">Sign Up</a>
                    </li>
                }
            </ul>
       
</nav>
    </header>
    
  
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Travel - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
