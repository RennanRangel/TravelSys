<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin TravelSys</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body">

<div class="admin-wrapper">
    <aside id="admin-sidebar" class="admin-sidebar collapsed">
        <div class="admin-logo">
            <span class="logo-text">Travel</span><i class="fas fa-plane-departure"></i>
        </div>
        <nav class="admin-nav">
            <a asp-controller="Admin" asp-action="Index" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <i class="fas fa-home"></i> <span>Visão Geral</span>
            </a>
            <a asp-controller="Admin" asp-action="GestaoViagens" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "GestaoViagens" ? "active" : "")">
                <i class="fas fa-plane-departure"></i> <span>Gestão de Viagens</span>
            </a>
            <a href="/Admin/GestaoUsuarios" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "GestaoUsuarios" ? "active" : "")">
                <i class="fas fa-users-cog"></i>
                <span class="nav-text">Gestão de Usuários</span>
            </a>
            <a asp-controller="Admin" asp-action="GestaoHospedagens" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "GestaoHospedagens" ? "active" : "")">
                <i class="fas fa-bed"></i> <span>Gestão de Hospedagens</span>
            </a>
            <a asp-controller="Admin" asp-action="AnalisarDados" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "AnalisarDados" ? "active" : "")">
                <i class="fas fa-chart-line"></i> <span>Analisar Dados</span>
            </a>
            <a asp-controller="Admin" asp-action="Relatorios" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Relatorios" ? "active" : "")">
                <i class="fas fa-file-alt"></i> <span>Relatórios</span>
            </a>
            <a asp-controller="Admin" asp-action="GerenciarTarefas" class="admin-nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "GerenciarTarefas" ? "active" : "")">
                <i class="fas fa-list-check"></i> <span>Gerenciar Tarefas</span>
            </a>
        </nav>
        
        <div class="admin-sidebar-footer">
            <a href="/" class="admin-nav-item">
                <i class="fas fa-external-link-alt"></i> <span>Back to Site</span>
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post" class="admin-logout-form">
                <button type="submit" class="admin-nav-item w-100 border-0 bg-transparent text-start">
                    <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
                </button>
            </form>
        </div>
    </aside>

    <main id="admin-main" class="admin-main expanded">
        <header class="admin-topbar">
            <div class="breadcrumb-area">
                <span class="breadcrumb-label">Pages</span> / <strong>@ViewData["Title"]</strong>
            </div>
            <div class="admin-user-info">
                <div class="user-text text-end">
                    <div class="admin-user-title">Administrator</div>
                    <div class="admin-user-subtitle">@User.Identity?.Name</div>
                </div>
                <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "Admin")&background=8DD3BB&color=fff" alt="Admin" class="admin-user-avatar">
            </div>
        </header>

        @RenderBody()
    </main>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.js"></script>

<script src="~/js/admin-layout.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
