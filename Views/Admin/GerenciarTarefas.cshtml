@model List<ProjetoHotelAviao.Models.AdminTask>
@{
    ViewData["Title"] = "Gerenciar Tarefas";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var afazer = Model.Where(t => t.Status == "afazer").ToList();
    var andamento = Model.Where(t => t.Status == "andamento").ToList();
    var concluido = Model.Where(t => t.Status == "concluido").ToList();
}

<div class="mgmt-header mb-4">
    <div>
        <h1 class="mgmt-title">Gerenciar Tarefas</h1>
        <p class="mgmt-subtitle">Administre o fluxo de trabalho e ordens de prioridade internas.</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
        <button class="btn-mgmt-primary" onclick="openNewTaskModal()"><i class="fas fa-plus"></i> Nova Tarefa</button>
    </div>
</div>

<div class="row g-4">
    <!-- Coluna A Fazer -->
    <div class="col-md-4">
        <div class="admin-card kanban-col">
            <h5 class="kanban-title"><i class="fas fa-clock text-warning"></i> A Fazer (<span id="count-afazer">@afazer.Count</span>)</h5>
            <div id="col-afazer" class="kanban-drop-zone" data-status="afazer">
                @foreach (var task in afazer)
                {
                    @await Html.PartialAsync("_TaskCard", task)
                }
            </div>
        </div>
    </div>

    <!-- Coluna Em Andamento -->
    <div class="col-md-4">
        <div class="admin-card kanban-col">
            <h5 class="kanban-title"><i class="fas fa-play-circle text-primary"></i> Em Andamento (<span id="count-andamento">@andamento.Count</span>)</h5>
            <div id="col-andamento" class="kanban-drop-zone" data-status="andamento">
                @foreach (var task in andamento)
                {
                    @await Html.PartialAsync("_TaskCard", task)
                }
            </div>
        </div>
    </div>

    <!-- Coluna Concluído -->
    <div class="col-md-4">
        <div class="admin-card kanban-col">
            <h5 class="kanban-title"><i class="fas fa-check-circle text-success"></i> Concluído (<span id="count-concluido">@concluido.Count</span>)</h5>
            <div id="col-concluido" class="kanban-drop-zone" data-status="concluido">
                @foreach (var task in concluido)
                {
                    @await Html.PartialAsync("_TaskCard", task)
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal Nova Tarefa -->
<div class="modal fade" id="newTaskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content admin-modal-content">
            <div class="modal-header admin-modal-header">
                <h5 class="modal-title admin-modal-title">Nova Tarefa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body admin-modal-body">
                <div class="mb-3">
                    <label class="form-label admin-form-label">Título</label>
                    <input type="text" class="form-control admin-form-input" id="taskTitle" placeholder="Ex: Revisar tarifas do hotel">
                </div>
                <div class="mb-3">
                    <label class="form-label admin-form-label">Descrição</label>
                    <textarea class="form-control admin-form-input" id="taskDescription" rows="3" placeholder="Descreva a tarefa..."></textarea>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label admin-form-label">Prioridade</label>
                        <select class="form-select admin-form-input" id="taskPriority">
                            <option value="baixa">Baixa</option>
                            <option value="media" selected>Média</option>
                            <option value="alta">Alta</option>
                            <option value="urgente">Urgente</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label admin-form-label">Coluna</label>
                        <select class="form-select admin-form-input" id="taskStatus">
                            <option value="afazer" selected>A Fazer</option>
                            <option value="andamento">Em Andamento</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer admin-modal-footer">
                <button type="button" class="btn-mgmt-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn-mgmt-primary" onclick="createTask()">Criar Tarefa</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/css/admin-tasks.css" asp-append-version="true">
    <script src="~/js/admin-tasks.js"></script>
}
