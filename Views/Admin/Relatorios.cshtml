@{
    ViewData["Title"] = "Relatórios";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    int totalFlightBookings = ViewBag.TotalFlightBookings ?? 0;
    int totalHotelBookings = ViewBag.TotalHotelBookings ?? 0;
    decimal flightRevenue = ViewBag.FlightRevenue ?? 0m;
    decimal hotelRevenue = ViewBag.HotelRevenue ?? 0m;
    int totalFlights = ViewBag.TotalFlights ?? 0;
    int totalHotels = ViewBag.TotalHotels ?? 0;
    int totalUsers = ViewBag.TotalUsers ?? 0;
    int totalReservas = totalFlightBookings + totalHotelBookings;
    decimal totalRevenue = flightRevenue + hotelRevenue;
}

<div class="mgmt-header mb-4">
    <div>
        <h1 class="mgmt-title">Relatórios</h1>
        <p class="mgmt-subtitle">Gere, visualize e baixe relatórios detalhados sobre o sistema.</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
    </div>
</div>

<!-- Resumo Rápido -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Voos Cadastrados</div>
            <div class="value">@totalFlights</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Hotéis Cadastrados</div>
            <div class="value">@totalHotels</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Total de Reservas</div>
            <div class="value">@totalReservas</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Usuários Registrados</div>
            <div class="value">@totalUsers</div>
        </div>
    </div>
</div>

<!-- Tabela de Relatórios Disponíveis -->
<div class="admin-card">
    <div class="table-responsive">
        <table class="mgmt-table">
            <thead>
                <tr>
                    <th>Nome do Relatório</th>
                    <th>Tipo</th>
                    <th>Dados</th>
                    <th>Receita</th>
                    <th class="text-end">Exportar</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <div class="report-name">Relatório Financeiro Completo</div>
                        <div class="report-desc">Inclui todas as reservas de voos e hotéis com valores e status.</div>
                    </td>
                    <td><span class="badge bg-light text-dark">Financeiro</span></td>
                    <td>@totalReservas reservas</td>
                    <td>@totalRevenue.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                    <td class="text-end">
                        <a asp-controller="Admin" asp-action="ExportFinanceiro" class="btn btn-sm btn-outline-primary"><i class="fas fa-download"></i> CSV</a>
                    </td>
                </tr>
                <tr>
                    <td>
                        <div class="report-name">Desempenho de Hotéis</div>
                        <div class="report-desc">Lista todos os hotéis com quantidade de reservas e receita gerada.</div>
                    </td>
                    <td><span class="badge bg-light text-dark">Operacional</span></td>
                    <td>@totalHotels hotéis · @totalHotelBookings reservas</td>
                    <td>@hotelRevenue.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                    <td class="text-end">
                        <a asp-controller="Admin" asp-action="ExportHoteis" class="btn btn-sm btn-outline-primary"><i class="fas fa-download"></i> CSV</a>
                    </td>
                </tr>
                <tr>
                    <td>
                        <div class="report-name">Desempenho de Voos</div>
                        <div class="report-desc">Lista todos os voos com quantidade de reservas e receita gerada.</div>
                    </td>
                    <td><span class="badge bg-light text-dark">Operacional</span></td>
                    <td>@totalFlights voos · @totalFlightBookings reservas</td>
                    <td>@flightRevenue.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</td>
                    <td class="text-end">
                        <a asp-controller="Admin" asp-action="ExportVoos" class="btn btn-sm btn-outline-primary"><i class="fas fa-download"></i> CSV</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
