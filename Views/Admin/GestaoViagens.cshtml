@model ProjetoHotelAviao.Models.ViewModels.AdminViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Gestão de Viagens";
}

<div class="mgmt-header">
    <h1>Gestão de Viagens</h1>
    <button class="btn btn-sm btn-outline-secondary" onclick="window.history.back()"><i class="fas fa-arrow-left"></i> Voltar</button>
</div>

<div class="mgmt-metrics-grid">
    <div class="metric-mini-card">
        <div class="metric-mini-content">
            <span class="label">Total de voos</span>
            <span class="value">@Model.Flights.Count</span>
        </div>
        <a href="#" class="ver-link">Ver voos</a>
    </div>
    <div class="metric-mini-card">
        <div class="metric-mini-content">
            <span class="label">Para hoje</span>
            <span class="value">@Model.Flights.Count(f => f.Departure != null && f.Departure.Contains(DateTime.Today.ToString("yyyy-MM-dd")))</span>
        </div>
        <a href="#" class="ver-link">Ver voos</a>
    </div>
    <div class="metric-mini-card">
        <div class="metric-mini-content">
            <span class="label">Preço Médio</span>
            <span class="value">R$ @(Model.Flights.Any() ? Model.Flights.Average(f => f.Price).ToString("N0") : "0")</span>
        </div>
    </div>

</div>

<div class="mgmt-container">
    <div class="mgmt-action-bar">
        <div class="mgmt-search-wrapper">
            <i class="fas fa-search"></i>
            <input type="text" class="mgmt-search-input" placeholder="Buscar voo por origem, destino ou companhia">
        </div>
        <div class="mgmt-buttons">
            <div class="dropdown">
                <button class="btn-mgmt-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="btnAcoesMassa">
                    <i class="fas fa-list-check"></i> Ações em massa
                </button>
                <ul class="dropdown-menu" style="border-radius: 12px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1); padding: 8px;">
                    <li><button class="dropdown-item text-danger d-flex align-items-center gap-2" onclick="deleteSelected('flight')"><i class="fas fa-trash"></i> Excluir Selecionados</button></li>
                </ul>
            </div>
            
            <div class="dropdown">
                <button class="btn-mgmt-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
                    <i class="fas fa-filter"></i> Filtros
                </button>
                <div class="dropdown-menu p-3 dropdown-menu-end" style="width: 280px; border-radius: 12px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                    <div class="mb-3">
                        <label class="form-label text-muted" style="font-size: 13px; font-weight: 500;">Preço Máximo</label>
                        <input type="range" class="form-range" min="0" max="10000" value="10000" step="100" id="filterPrice" oninput="document.getElementById('priceVal').innerText = this.value">
                        <div class="d-flex justify-content-between text-muted" style="font-size: 11px;">
                            <span>R$ 0</span>
                            <span>R$ <span id="priceVal">10000</span></span>
                        </div>
                    </div>
                    <button class="btn btn-primary w-100" style="border-radius: 8px; font-size: 13px;" onclick="applyFilters()">Aplicar Filtro</button>
                </div>
            </div>
            <div class="dropdown">
                <button class="btn-mgmt-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-plus"></i> Novo Voo
                </button>
                <ul class="dropdown-menu dropdown-menu-end" style="border-radius: 12px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1); padding: 8px;">
                    <li>
                        <a class="dropdown-item p-2 px-3 d-flex align-items-center gap-2" asp-action="CreateFlight" style="border-radius: 8px;">
                            <i class="fas fa-file-lines text-muted"></i> Padrão
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="mgmt-status-filters">
        <label class="status-filter-item"><input type="radio" name="status-filter" value="all"> Tudo <span class="count">(@Model.Flights.Count)</span></label>
        <label class="status-filter-item"><input type="radio" name="status-filter" value="publicada" checked> Publicada <span class="count">(@Model.Flights.Count(f => f.Status?.ToLower() == "publicada"))</span></label>
        <label class="status-filter-item"><input type="radio" name="status-filter" value="cancelada"> Cancelada <span class="count">(@Model.Flights.Count(f => f.Status?.ToLower() == "cancelada"))</span></label>
    </div>

    <table class="mgmt-table">
        <thead>
            <tr>
                <th style="width: 40px;"><input type="checkbox" id="selectAllCheckbox"></th>
                <th>Companhia</th>
                <th>Rota</th>
                <th>Horários</th>
                <th>Preço</th>
                <th>Status</th>
                <th style="text-align: right;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flight in Model.Flights)
            {
                <tr data-status="@((flight.Status ?? "publicada").ToLower())">
                    <td><input type="checkbox" class="row-checkbox" value="@flight.Id"></td>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <img src="@flight.Logo" style="width: 32px; height: 32px; object-fit: contain;">
                            <div>
                                <div style="font-weight: 600;">@flight.Airline</div>
                                <div style="font-size: 11px; color: var(--admin-text-muted);">#@flight.Id</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div style="font-weight: 500;">@flight.From → @flight.To</div>
                        <div style="font-size: 11px; color: var(--admin-text-muted);">@flight.TripType</div>
                    </td>
                    <td>
                        <div style="font-size: 13px;">@flight.Departure - @flight.Arrival</div>
                    </td>
                    <td data-price="@flight.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                        <div style="font-weight: 600; color: #112211;">R$ @flight.Price.ToString("N2")</div>
                    </td>
                    <td>
                        <span class="mgmt-status-badge badge-blue">@(flight.Status ?? "Publicada")</span>
                    </td>
                    <td>
                        <div class="mgmt-actions-cell">
                            <a asp-action="EditFlight" asp-route-id="@flight.Id" class="mgmt-icon-btn"><i class="fas fa-edit"></i></a>
                            <form asp-action="DeleteFlight" method="post" onsubmit="return confirm('Excluir este voo?')">
                                <input type="hidden" name="id" value="@flight.Id" />
                                <button type="submit" class="mgmt-icon-btn" style="color: #D93025;"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/admin-management.js"></script>
}
