@model ProjetoHotelAviao.Models.ViewModels.AdminViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Visão Geral";
}

<!-- VISÃO GERAL CONTENT -->
<div id="overview" class="admin-content-pane active">
    <section class="admin-hero">
        <div class="hero-text">
            <h1>Desenvolva sua plataforma com controle e insights refinados!</h1>
            <p>Bem-vindo de volta, Administrador. Aqui está um resumo do desempenho da sua rede de viagens.</p>
        </div>
        <div class="hero-illustration">
            <i class="fas fa-home"></i>
        </div>
    </section>


    <div class="admin-row-cards">
        <!-- Card 1: Reservas do dia -->
        <div class="special-card">
            <div class="special-card-header">
                <h3>Reservas do dia</h3>
                <i class="fas fa-pen edit-icon-mini"></i>
            </div>
            <div class="illustration-area">
                <div class="calendar-mockup">
                    <i class="fas fa-calendar-alt"></i>
                </div>
                <p class="fw-bold card-empty-text">Você não possui<br>reservas agendadas</p>
            </div>
        </div>

        <!-- Card 2: Selo de Feedback -->
        <div class="special-card">
            <div class="special-card-header">
                <div class="indicator-icon indicator-accent">
                    <i class="fas fa-certificate"></i>
                </div>
                <h3>Selo de Feedback</h3>
            </div>
            <p class="fw-bold card-secondary-title">Acompanhe os indicadores dos seus serviços e garanta seu Selo de Excelência!</p>
            <p class="card-body-text">
                Com o Selo, sua empresa se torna referência, atrai os melhores viajantes e mostra que a qualidade é prioridade. <a href="#" class="link-premium">Conheça os novos critérios</a>
            </p>
            
            <div class="indicator-row">
                <div class="indicator-box">
                    <div class="indicator-icon">
                        <i class="fas fa-clipboard-check"></i>
                    </div>
                    <div class="indicator-text">
                        <div>98.5% dos voos</div>
                        <div>com feedback positivo</div>
                        <a href="#" class="link-mini">Ver detalhes</a>
                    </div>
                </div>
                <div class="indicator-box">
                    <div class="indicator-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="indicator-text">
                        <div>Zero reclamações</div>
                        <div>nos últimos 90 dias</div>
                    </div>
                </div>
            </div>
            <p class="footer-text">A próxima edição do selo será no dia 01/07/2026.</p>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/admin-upload.js"></script>
}
