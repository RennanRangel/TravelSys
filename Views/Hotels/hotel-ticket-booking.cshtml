@model ProjetoHotelAviao.Models.HotelBooking
@{
    ViewData["Title"] = "Reservation Confirmed - Travel";
    var hotel = Model.Hotel;
}

@section Styles {
    <link rel="stylesheet" href="~/css/hotel-ticket.css" asp-append-version="true">
}

<div class="main-container">
    <div class="breadcrumbs">
        <a href="#">Turkey</a> <i class="fas fa-chevron-right"></i>
        <a href="#">Istanbul</a> <i class="fas fa-chevron-right"></i>
        <span>@hotel?.Name</span>
    </div>

    <header class="ticket-header-top">
        <div class="hotel-title-wrap">
            <h1>@hotel?.Name</h1>
            <p class="location"><i class="fas fa-map-marker-alt"></i> @hotel?.Location</p>
        </div>
        <div class="ticket-actions-wrap" style="text-align: right;">
            <div class="price-tag">$@Model.TotalPrice.ToString("F0")</div>
            <div class="ticket-actions">
                <button class="btn-action-icon"><i class="fas fa-share-alt"></i></button>
                <button class="btn-download">Download</button>
            </div>
        </div>
    </header>

    <div class="ticket-card">
        <!-- Left Panel: Dates -->
        <div class="ticket-left">
            <div class="ticket-date">
                <strong>@Model.CheckIn.ToString("ddd, MMM d")</strong>
                <span>Check-In</span>
            </div>
            <div class="ticket-timeline">
                <div class="line"></div>
                <i class="fas fa-bed"></i>
                <div class="line"></div>
            </div>
            <div class="ticket-date">
                <strong>@Model.CheckOut.ToString("ddd, MMM d")</strong>
                <span>Check-Out</span>
            </div>
        </div>

        <!-- Center Panel: Guest & Info -->
        <div class="ticket-center">
            <div class="guest-profile-header">
                <div class="guest-info-box">
                    <img src="https://ui-avatars.com/api/?name=@(Model.UserName ?? Model.UserEmail)&background=fff&color=8DD3BB" alt="Guest" class="guest-avatar">
                    <h3>@(Model.UserName ?? "James Doe")</h3>
                </div>
                <div class="room-type-tag">
                    @Model.RoomType
                </div>
            </div>

            <div class="ticket-info-grid">
                <div class="info-item-ticket">
                    <div class="icon-box"><i class="fas fa-clock"></i></div>
                    <div class="text-wrap">
                        <span class="label">Check-In time</span>
                        <span class="value">12:00pm</span>
                    </div>
                </div>
                <div class="info-item-ticket">
                    <div class="icon-box"><i class="fas fa-clock"></i></div>
                    <div class="text-wrap">
                        <span class="label">Check-Out time</span>
                        <span class="value">11:30pm</span>
                    </div>
                </div>
                <div class="info-item-ticket">
                    <div class="icon-box"><i class="fas fa-door-open"></i></div>
                    <div class="text-wrap">
                        <span class="label">Room no.</span>
                        <span class="value">On arrival</span>
                    </div>
                </div>
            </div>

            <div class="ticket-barcode-section">
                <span>RESERVATION CODE</span>
                <h4>@Model.ReservationNumber</h4>
                <div class="barcode-wrap" style="margin-top: 10px;">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/11/Barcode_EAN8_example.svg/1200px-Barcode_EAN8_example.svg.png" 
                         alt="Barcode" 
                         style="width: 100%; max-width: 400px; height: 60px; object-fit: cover;">
                </div>
            </div>
        </div>

        <!-- Right Panel: Branding -->
        <div class="ticket-right">
            <div class="hotel-branding">
                <p style="letter-spacing: 4px; font-size: 10px; opacity: 0.6; margin-bottom: 8px;">HOTEL BRAND</p>
                <h2>@hotel?.Name.Split(' ')[0]</h2>
                <p style="letter-spacing: 2px; font-size: 12px; opacity: 0.6; margin-top: 8px;">ISTANBUL</p>
            </div>
        </div>
    </div>

    <section class="terms-footer">
        <h2>Terms and Conditions</h2>
        
        <div class="terms-block">
            <h3>Payments</h3>
            <ul>
                <li>If you are purchasing your ticket using a debit or credit card via the Website, we will process these payments via the automated secure common payment gateway which will be subject to fraud screening purposes.</li>
                <li>If you do not supply the correct card billing address and/or cardholder information, your booking will not be confirmed...</li>
                <li>Golobe may require the card holder to provide additional payment verification upon request...</li>
            </ul>
        </div>

        <div class="terms-block">
            <h3>Contact Us</h3>
            <p>If you have any questions about our Website or our Terms of Use, please contact:</p>
            <p>
                Golobe Group Q.C.S.C<br>
                Golobe Tower<br>
                P.O. Box 22550<br>
                Doha, State of Qatar
            </p>
            <p>Further contact details can be found at <a href="#" style="color: #FF8682;">golobe.com/help</a></p>
        </div>
    </section>
</div>

@section Scripts {
    <!-- FontAwesome handles icons -->
}
