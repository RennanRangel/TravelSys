@model ProjetoHotelAviao.Models.Hotel
@{
    ViewData["Title"] = "Hotel Booking - Travel";
    
    var hotelFallback = "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=600";
    var hotelImg = Model.MainImage;
    if (string.IsNullOrEmpty(hotelImg) || hotelImg.Contains("flight") || hotelImg.Contains("A380")) {
        hotelImg = hotelFallback;
    }

    var baseFare = Model.Price;
    var discount = 0m;
    var taxes = baseFare * 0.1m;
    var serviceFee = 5m;
    var total = baseFare - discount + taxes + serviceFee;
}

@section Styles {
    <link rel="stylesheet" href="/css/hotel-details.css" asp-append-version="true">
    <link rel="stylesheet" href="/css/hotel-booking.css" asp-append-version="true">
}

<div class="main-container">
    <div class="breadcrumbs">
        <a href="#">Turkey</a> <i class="fas fa-chevron-right"></i>
        <a href="#">Istanbul</a> <i class="fas fa-chevron-right"></i>
        <span>@Model.Name</span>
    </div>

    <div class="booking-layout">
        <div class="booking-content">
            <div class="booking-summary-box">
                <div class="room-header">
                    <h1>@(ViewBag.RoomType ?? "Superior room - 1 double bed or 2 twin beds")</h1>
                    <div class="room-price">
                        $@Model.Price<span>/night</span>
                    </div>
                </div>

                <div class="hotel-card">
                    <div class="hotel-logo">
                        <img src="https://ui-avatars.com/api/?name=CVK+Park&background=112211&color=fff&size=120" alt="Hotel Logo">
                    </div>
                    <div class="hotel-info-text">
                        <h3>@Model.Name</h3>
                        <p><i class="fas fa-map-marker-alt"></i> Gümüssuyu Mah. Inönü Cad. No:8, Istanbul 34437</p>
                    </div>
                </div>

                <div class="booking-dates booking-dates-noborder">
                    <div class="date-box">
                        <strong>Thursday, Dec 8</strong>
                        <span>Check-In</span>
                    </div>
                    <div class="date-path">
                        <div class="line"></div>
                        <i class="fas fa-hotel"></i>
                        <div class="line"></div>
                    </div>
                    <div class="date-box date-box-right">
                        <strong>Friday, Dec 9</strong>
                        <span>Check-Out</span>
                    </div>
                </div>
            </div>

            <div class="payment-plans">
                <div class="payment-card selected" onclick="selectPayment(this, 'full')">
                    <div class="payment-info">
                        <h4>Pay in full</h4>
                        <p>Pay the total and you are all set</p>
                    </div>
                    <div class="radio-circle"></div>
                </div>
                <div class="payment-card" onclick="selectPayment(this, 'part')">
                    <div class="payment-info">
                        <h4>Pay part now, part later</h4>
                        <p>Pay 50% now, and the rest later. No extra fees.</p>
                    </div>
                    <div class="radio-circle"></div>
                </div>
            </div>

            <section class="auth-section">
                <h2>Login or Sign up to book</h2>
                <div class="phone-input-group">
                    <input type="text" placeholder="Phone Number" value="">
                </div>
                <p class="auth-notice">
                    We'll call or text you to confirm your number. Standard message and data rates apply. <a href="#">Privacy Policy</a>
                </p>
                <button class="btn-continue">Continue</button>

                <div class="divider-text">Or</div>

                <div class="social-logins">
                    <button class="social-btn"><i class="fab fa-facebook"></i></button>
                    <button class="social-btn"><i class="fab fa-google"></i></button>
                    <button class="social-btn"><i class="fab fa-apple"></i></button>
                </div>

                <button class="btn-email-login">
                    <i class="far fa-envelope"></i> Continue with email
                </button>
            </section>
        </div>

        <aside class="summary-sidebar">
            <div class="summary-hotel-header">
                <div class="summary-image">
                    <img src="@hotelImg" alt="Room">
                </div>
                <div class="summary-meta">
                    <p class="summary-hotel-name">@Model.Name</p>
                    <h3>@(ViewBag.RoomType ?? "Superior room - 1 double bed or 2 twin beds")</h3>
                    <div class="rating">
                        <span class="badge">@Model.Rating</span>
                        <span class="label">Very Good</span>
                        <span class="reviews">54 reviews</span>
                    </div>
                </div>
            </div>

            <div class="protection-box">
                Your booking is protected by <strong>golobe</strong>
            </div>

            <div class="price-details">
                <h4>Price Details</h4>
                <div class="price-row">
                    <span>Base Fare</span>
                    <span>$@baseFare</span>
                </div>
                <div class="price-row">
                    <span>Discount</span>
                    <span>$@discount</span>
                </div>
                <div class="price-row">
                    <span>Taxes</span>
                    <span>$@taxes.ToString("F2")</span>
                </div>
                <div class="price-row">
                    <span>Service Fee</span>
                    <span>$@serviceFee</span>
                </div>
                <div class="price-row total">
                    <span>Total</span>
                    <span>$@total.ToString("F2")</span>
                </div>
            </div>

            <form asp-action="Payment" asp-controller="Hotels" method="get" class="sidebar-form-margin">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="roomType" value="@ViewBag.RoomType" />
                <button type="submit" class="btn-continue btn-no-bottom-margin">Continue to Payment</button>
            </form>
        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/js/hotel-booking.js"></script>
}
