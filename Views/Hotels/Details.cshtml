@model ProjetoHotelAviao.Models.Hotel
@{
    ViewData["Title"] = Model.Name + " - Hotel Details";
    
    // Improved Gallery Image Logic with Hotel specific fallbacks
    var hotelFallbacks = new[] {
        "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=1200", // Grand Lobby
        "https://images.unsplash.com/photo-1571011272708-34907931336c?w=800", // Pool
        "https://images.unsplash.com/photo-1590490360182-c33d57733427?w=800", // Bed
        "https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=800", // Bathroom
        "https://images.unsplash.com/photo-1540518614846-7eded433c457?w=800"  // View
    };

    var mainImg = Model.MainImage;
    if (string.IsNullOrEmpty(mainImg) || mainImg.Contains("flight") || mainImg.Contains("A380"))
    {
        mainImg = hotelFallbacks[0];
    }

    var galleryImages = new List<string>();
    if (!string.IsNullOrEmpty(Model.GalleryImages) && !Model.GalleryImages.Contains("[]"))
    {
        try { 
            galleryImages = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.GalleryImages) ?? new List<string>(); 
        } catch { }
    }

    // Ensure we have 4 images for the small grid
    for (int i = 0; i < 4; i++) {
        if (galleryImages.Count <= i || galleryImages[i].Contains("flight") || galleryImages[i].Contains("A380")) {
            if (galleryImages.Count <= i) galleryImages.Add(hotelFallbacks[i + 1]);
            else galleryImages[i] = hotelFallbacks[i + 1];
        }
    }
}

@section Styles {
    <link rel="stylesheet" href="/css/hotel-details.css" asp-append-version="true">
}

<div id="hotel-details" class="main-container">
    <div class="breadcrumbs">
        <a href="#">Stays</a> <i class="fas fa-chevron-right"></i>
        <a href="#">Turkey</a> <i class="fas fa-chevron-right"></i>
        <a href="#">Istanbul</a> <i class="fas fa-chevron-right"></i>
        <span>@Model.Name</span>
    </div>

    <div class="hotel-header">
        <div class="header-left">
            <div class="title-stars">
                <h1>@Model.Name</h1>

            </div>
            <div class="location-box">
                <i class="fas fa-map-marker-alt"></i>
                <span>Gümüssuyu Mah. Inönü Cad. No:8, Istanbul 34437</span>
            </div>
            @if (Model.IsAccessible)
            {
                <div class="accessibility-badge accessibility-badge-details">
                    <i class="fas fa-wheelchair"></i>
                    <span>Accessible - PCD assistance available</span>
                </div>
            }
        </div>
        <div class="header-right">
            <div class="price-box">
                <span class="price">$@Model.Price</span>
                <span class="unit">/night</span>
            </div>
            <div class="action-buttons">
                <button class="btn-icon favorite"><i class="far fa-heart"></i></button>
                <button class="btn-icon share"><i class="fas fa-share-alt"></i></button>
                <form asp-action="Booking" asp-controller="Hotels" method="get" class="form-inline-block">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn-book-now">Book now</button>
                </form>
            </div>
        </div>
    </div>

    <div class="hotel-gallery">
        <div class="gallery-large">
            <img src="@mainImg" alt="Main View">
        </div>
        <div class="gallery-small-grid">
            @for(int i=0; i<4; i++) {
                <div class="gallery-small-item @(i == 3 ? "view-all" : "")">
                    <img src="@galleryImages[i]" alt="Gallery Image @i">
                    @if(i == 3) {
                        <button class="btn-view-all">View all photos</button>
                    }
                </div>
            }
        </div>
    </div>

    <hr class="section-divider">

    <section class="overview-section">
        <h2>Overview</h2>
        <p class="description description-pre">
            @if (string.IsNullOrEmpty(Model.Overview) || Model.Overview.Trim().ToUpper() == "AAAA")
            {
                @:Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
            }
            else
            {
                @Model.Overview
            }
        </p>
        
        <div class="overview-badges">

            <div class="badge-item highlight vertical-badge">
                <img src="/images/Stars.png" alt="Stars" class="amenity-star">
                <span>Near park</span>
            </div>
            <div class="badge-item highlight vertical-badge">
                <img src="/images/Stars.png" alt="Stars" class="amenity-star">
                <span>Near nightlife</span>
            </div>
            <div class="badge-item highlight vertical-badge">
                <img src="/images/Stars.png" alt="Stars" class="amenity-star">
                <span>Near theater</span>
            </div>
            <div class="badge-item highlight vertical-badge">
                <img src="/images/Stars.png" alt="Stars" class="amenity-star">
                <span>Clean Hotel</span>
            </div>
        </div>
    </section>

    <hr class="section-divider">

    <section class="rooms-section">
        <h2>Available Rooms</h2>
        <div class="rooms-list">
            @{
                var roomTypes = new[] {
                    "Superior room - 1 double bed or 2 single beds",
                    "Superior room - City view - 1 double bed or 2 single beds",
                    "Superior room - Sea view - 1 double bed or 2 single beds",
                    "Superior room - City view - 1 double bed or 2 single beds"
                };
            }
            @for(int i=0; i<4; i++) {
                var roomPrice = Model.Price + (i * 20);
                <div class="room-card">
                    <div class="room-img">
                        <img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?w=200" alt="Room Image">
                    </div>
                    <div class="room-info">
                        <h3>@roomTypes[i]</h3>
                    </div>
                    <div class="room-actions">
                        <span class="room-price">$@roomPrice</span>
                        <a href="@Url.Action("Booking", "Hotels", new { id = Model.Id, roomType = roomTypes[i] })" class="btn-book-room">Book now</a>
                    </div>
                </div>
            }
        </div>
    </section>

    <hr class="section-divider">

    <section class="location-map-section">
        <div class="section-header">
            <h2>Location/Map</h2>
            <button class="btn-view-map">View on google maps</button>
        </div>
        <div class="map-placeholder">
            <img src="https://images.unsplash.com/photo-1524661135-423995f22d0b?w=1200" alt="Map Placeholder" class="map-img-fluid">
            <div class="map-location-tag">
                <i class="fas fa-map-marker-alt"></i>
                <span>Gümüssuyu Mah. Inönü Cad. No:8, Istanbul 34437</span>
            </div>
        </div>
    </section>

    <hr class="section-divider">

    <section class="amenities-section">
        <h2>Amenities</h2>
        <div class="amenities-grid">
            @if (!string.IsNullOrEmpty(Model.Amenities))
            {
                var amenitiesList = Model.Amenities.Split(new[] { "\n", "\r\n" }, StringSplitOptions.RemoveEmptyEntries);
                foreach (var item in amenitiesList)
                {
                    <div class="amenity">
                        <i class="fas fa-check-circle"></i> @item.TrimStart('-', ' ', '*')
                    </div>
                }
            }
            else
            {
                <div class="amenity"><i class="fas fa-swimming-pool"></i> Outdoor pool</div>
                <div class="amenity"><i class="fas fa-hot-tub"></i> Indoor pool</div>
                <div class="amenity"><i class="fas fa-dumbbell"></i> Spa and wellness center</div>
                <div class="amenity"><i class="fas fa-utensils"></i> Restaurant</div>
                <div class="amenity"><i class="fas fa-concierge-bell"></i> Room service</div>
                <div class="amenity"><i class="fas fa-dumbbell"></i> Fitness center</div>
                <div class="amenity"><i class="fas fa-cocktail"></i> Bar/Lounge</div>
                <div class="amenity"><i class="fas fa-wifi"></i> Free Wi-Fi</div>
                <div class="amenity"><i class="fas fa-mug-hot"></i> Tea/coffee machine</div>
            }
        </div>
    </section>


</div>
