@model ProjetoHotelAviao.Models.Hotel
@{
    ViewData["Title"] = "Hotel Payment - Travel";
    
    var hotelFallback = "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=600";
    var hotelImg = Model.MainImage;
    if (string.IsNullOrEmpty(hotelImg) || hotelImg.Contains("flight") || hotelImg.Contains("A380")) {
        hotelImg = hotelFallback;
    }

    var baseFare = Model.Price;
    var discount = 0m;
    var taxes = baseFare * 0.1m;
    var serviceFee = 5m;
    var total = baseFare - discount + taxes + serviceFee;
    var partTotal = total / 2;

    var userCards = ViewBag.UserCards as List<ProjetoHotelAviao.Models.UserCard>;
}

@section Styles {
    <link rel="stylesheet" href="/css/hotel-payment.css" asp-append-version="true">
}

<div class="main-container">
    <!-- Breadcrumbs -->
    <div class="breadcrumbs">
        <a href="#">Turkey</a> <i class="fas fa-chevron-right"></i>
        <a href="#">Istanbul</a> <i class="fas fa-chevron-right"></i>
        <span>@Model.Name</span>
    </div>

    <div class="booking-layout">
        <!-- Left Column -->
        <div class="booking-content">
            <div class="booking-summary-box">
                <div class="room-header">
                    <h1>Superior room - 1 double bed or 2 twin beds</h1>
                    <div class="room-price">
                        $@Model.Price<span>/night</span>
                    </div>
                </div>

                <div class="hotel-card">
                    <div class="hotel-logo">
                        <img src="https://ui-avatars.com/api/?name=CVK+Park&background=112211&color=fff&size=120" alt="Hotel Logo">
                    </div>
                    <div class="hotel-info-text">
                        <h3>@Model.Name</h3>
                        <p><i class="fas fa-map-marker-alt"></i> Gümüssuyu Mah. Inönü Cad. No:8, Istanbul 34437</p>
                    </div>
                </div>

                <div class="booking-dates" style="border-bottom:none; margin-bottom:0; padding: 24px 0 0 0;">
                    <div class="date-box">
                        <strong>Thursday, Dec 8</strong>
                        <span>Check-In</span>
                    </div>
                    <div class="date-path">
                        <div class="line"></div>
                        <i class="fas fa-hotel"></i>
                        <div class="line"></div>
                    </div>
                    <div class="date-box" style="text-align: right;">
                        <strong>Friday, Dec 9</strong>
                        <span>Check-Out</span>
                    </div>
                </div>
            </div>

            <div class="payment-plans">
                <div class="payment-card selected" onclick="updatePayment('full', @total.ToString(System.Globalization.CultureInfo.InvariantCulture))">
                    <div class="payment-info">
                        <h4>Pay in full</h4>
                        <p>Pay the total and you are all set</p>
                    </div>
                    <div class="radio-circle"></div>
                </div>
                <div class="payment-card" onclick="updatePayment('part', @partTotal.ToString(System.Globalization.CultureInfo.InvariantCulture))">
                    <div class="payment-info">
                        <h4>Pay part now, part later</h4>
                        <p>Pay $@partTotal.ToString("F2") now, and the rest later. No extra fees.</p>
                    </div>
                    <div class="radio-circle"></div>
                </div>
            </div>

            <section class="payment-methods">
                @if (userCards != null && userCards.Any())
                {
                    @foreach (var card in userCards)
                    {
                        <div class="card-item @(card == userCards.First() ? "selected" : "")" onclick="selectCard(this)">
                            <div class="card-info">
                                <i class="fab fa-cc-@(card.CardType.ToLower())" style="font-size: 32px; color: #112211;"></i>
                                <span class="card-number">**** @card.CardNumber.Substring(Math.Max(0, card.CardNumber.Length - 4))</span>
                                <span class="card-expiry">@card.ExpiryDate</span>
                            </div>
                            <div class="radio-circle"></div>
                        </div>
                    }
                }
                else
                {
                    <!-- Mock Card just to show UI if no cards -->
                    <div class="card-item selected">
                        <div class="card-info">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg" alt="Visa" class="card-brand">
                            <span class="card-number">**** 4321</span>
                            <span class="card-expiry">02/27</span>
                        </div>
                        <div class="radio-circle"></div>
                    </div>
                }

                <div class="add-card-placeholder" onclick="toggleModal(true)">
                    <div class="add-icon">
                        <i class="fas fa-plus"></i>
                    </div>
                    <span>Add a new card</span>
                </div>
            </section>
        </div>

        <!-- Right Column (Sidebar) -->
        <aside class="summary-sidebar">
            <div class="summary-hotel-header">
                <div class="summary-image">
                    <img src="@hotelImg" alt="Room">
                </div>
                <div class="summary-meta">
                    <p style="opacity:0.6; font-size:12px; margin-bottom:4px;">CVK Park Bosphorus...</p>
                    <h3>Superior room - 1 double bed or 2 twin beds</h3>
                    <div class="rating">
                        <span class="badge">@Model.Rating</span>
                        <span class="label">Very Good</span>
                        <span class="reviews">54 reviews</span>
                    </div>
                </div>
            </div>

            <div class="protection-box">
                Your booking is protected by <strong>golobe</strong>
            </div>

            <div class="price-details">
                <h4>Price Details</h4>
                <div class="price-row">
                    <span>Base Fare</span>
                    <span>$@baseFare</span>
                </div>
                <div class="price-row">
                    <span>Discount</span>
                    <span>$@discount</span>
                </div>
                <div class="price-row">
                    <span>Taxes</span>
                    <span>$@taxes.ToString("F2")</span>
                </div>
                <div class="price-row">
                    <span>Service Fee</span>
                    <span>$@serviceFee</span>
                </div>
                <div class="price-row total">
                    <span>Total</span>
                    <span id="totalPriceDisplay">$@total.ToString("F2")</span>
                </div>
            </div>

            <form asp-action="CompletePayment" asp-controller="Hotels" method="post" style="margin-top:32px;">
                <input type="hidden" name="hotelId" value="@Model.Id" />
                <input type="hidden" name="paymentType" id="selectedPaymentType" value="full" />
                <button type="submit" class="btn-continue" style="margin-bottom:0;">Confirm Booking</button>
            </form>
        </aside>
    </div>
</div>

<!-- Modal Add Card -->
<div class="modal-sistema" id="addCardModal">
    <div class="modal-content">
        <span class="modal-close" onclick="toggleModal(false)">&times;</span>
        <h2 style="margin-bottom:24px;">Add a new Card</h2>
        <form asp-controller="Cards" asp-action="AddCard" method="post">
            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
            <div class="form-group">
                <label>Card Number</label>
                <input type="text" name="cardNumber" placeholder="0000 0000 0000 0000" required>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Expiry Date</label>
                    <input type="text" name="expiryDate" placeholder="MM/YY" required>
                </div>
                <div class="form-group">
                    <label>CVC</label>
                    <input type="text" name="cvc" placeholder="123" required>
                </div>
            </div>
            <div class="form-group">
                <label>Name on Card</label>
                <input type="text" name="nameOnCard" required>
            </div>
            <button type="submit" class="btn-submit" style="width:100%;">Add Card</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function updatePayment(type, amount) {
            document.querySelectorAll('.payment-card').forEach(card => card.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
            document.getElementById('selectedPaymentType').value = type;
            document.getElementById('totalPriceDisplay').textContent = '$' + amount.toFixed(2);
        }

        function selectCard(element) {
            document.querySelectorAll('.card-item').forEach(card => card.classList.remove('selected'));
            element.classList.add('selected');
        }

        function toggleModal(show) {
            document.getElementById('addCardModal').classList.toggle('active', show);
        }
    </script>
}
